# Local .terraform directories
**/.terraform/*
**/.terragrunt-cache/*
**/*.pkrvars.hcl*
**/.DS_Store

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files you do wish to add to version control using negated pattern
#
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc
.venv/**

*.zip
.vscode/launch.json
.terraform-docs.yml
.pre-commit-config.yaml
#
# Terragrunt
.terragrunt-cache/**
terragrunt-debug.tfvars
terragrunt-debug.tf

# Ignore sensitive files
*.pem
*.key
*.pub
backend-config-secret.yaml


cyngular_new_site.log
.env*
**/.env
**/*.log
.terraform.lock.hcl

tmp/
logs/
# Terraform plan analysis temp files
/tmp/terraform-plans/

# Terraform plan analysis reports (ignore generated reports, keep directory)
reports/*.md
reports/*.json
!reports/.gitkeep

tmpl/

# Lambda layers build artifacts
Lambda/Layers/**/.venv/
Lambda/Layers/**/build/
Lambda/Layers/**/dist/

# Beads metadata (auto-generated)
.beads/beads.left.meta.json
.beads/beads.db*
.beads/daemon.*
.beads/bd.sock

.vscode/
thoughts/
.letta/